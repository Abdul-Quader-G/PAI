variables = ['A','B','C']
domains = {'A':[1,2,3],'B':[1,2,3],'C':[1,2,3]}

def valid(var, val, assignment):
    for v in assignment:
        if assignment[v] == val:
            return False
    return True

def backtrack(assignment):
    if len(assignment) == len(variables):
        return assignment

    var = [v for v in variables if v not in assignment][0]

    for val in domains[var]:
        if valid(var, val, assignment):
            assignment[var] = val
            result = backtrack(assignment)
            if result:
                return result
            del assignment[var]

    return None

solution = backtrack({})

if solution:
    print("Solution found:")
    for k,v in solution.items():
        print(k,":",v)
else:
    print("No solution")
    
